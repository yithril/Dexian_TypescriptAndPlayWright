{
  "name": "bulkbox",
  "version": "1.0.0",
  "description": "BulkBox - sample industrial-supply storefront used for the TypeScript & Playwright workshop.",
  "private": true,
  "scripts": {
    "postinstall": "npm --prefix frontend install",
    "api": "json-server --watch mock-api/db.json --port 3001",
    "frontend": "npm --prefix frontend run start",
    "dev": "concurrently -n api,web -c yellow,cyan \"npm:api\" \"npm:frontend\"",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "json-server": "^0.17.4"
  }
}
